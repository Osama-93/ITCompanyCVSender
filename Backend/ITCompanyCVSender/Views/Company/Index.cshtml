@model IEnumerable<ITCompanyCVSender.Models.CompanyVM>

@{
    ViewBag.Title = "Companies";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .lds-dual-ring {
        display: inline-block;
        width: 20px;
        height: 20px;
    }
    .lds-dual-ring:after {
        content: " ";
        display: block;
        width: 14px;
        height: 14px;
        margin: 1px;
        border-radius: 50%;
        border: 2px solid #fff;
        border-color: #fff transparent #fff transparent;
        animation: lds-dual-ring 1.2s linear infinite;
    }
    
</style>
<!-- Bootstrap & DataTables CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.bootstrap5.min.css" />

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Company List</h2>
        @Html.ActionLink("Create New", "Create", null, new { @class = "btn btn-primary" })
    <button id="findMissingEmailsBtn" class="btn btn-outline-primary">
        <span id="findText">Find Missing Emails</span>
        <span id="findSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
        <span id="findStatus" class="ms-2"></span>

    </button>   
        <button id="sendAllBtn" class="btn btn-primary">
            <span id="btnText">Send to All</span>
            <span id="loadingSpinner" class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
        </button>

        <div id="sendStatus" class="mt-2"></div>
    </div>

    <div class="table-responsive">
        <table id="companiesTable" class="table table-striped table-bordered nowrap table-hover" style="width:100%">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.First().Name)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Industry)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Website)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Email)</th>
                    <th>@Html.DisplayNameFor(model => model.First().PhoneNumber)</th>
                    <th>@Html.DisplayNameFor(model => model.First().LinkedInUrl)</th>
                    <th>@Html.DisplayNameFor(model => model.First().City)</th>
                    <th>@Html.DisplayNameFor(model => model.First().ContactFormUrl)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Status)</th>
                    <th>@Html.DisplayNameFor(model => model.First().ContactName)</th>
                    <th>@Html.DisplayNameFor(model => model.First().AltEmail)</th>
                    <th>@Html.DisplayNameFor(model => model.First().AltNumber)</th>
                    <th>@Html.DisplayNameFor(model => model.First().WhatsApp)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Notes)</th>
                    <th>@Html.DisplayNameFor(model => model.First().DateAdded)</th>
                    <th>@Html.DisplayNameFor(model => model.First().UpdatedDate) </th>
                    <th>Is Active</th>
                    <th>Actions</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.isActive == true ? "table-success" : "table-danger")">
                        <td>@item.Name</td>
                        <td>@item.Industry</td>
                        <td><a href="@item.Website" target="_blank">@item.Website</a></td>
                        <td>@item.Email</td>
                        <td>@item.PhoneNumber</td>
                        <td><a href="@item.LinkedInUrl" target="_blank">@item.LinkedInUrl</a></td>
                        <td>@item.City</td>
                        <td><a href="@item.ContactFormUrl" target="_blank">@item.ContactFormUrl</a></td>
                        <td>@item.Status</td>
                        <td>@item.ContactName</td>
                        <td>@item.AltEmail</td>
                        <td>@item.AltNumber</td>
                        <td><a href="https://wa.me/@item.WhatsApp" target="_blank">Send Message To : @item.WhatsApp</a></td>
                        <td>@item.Notes</td>
                        <td>@(item.DateAdded.HasValue ? item.DateAdded.Value.ToShortDateString() : "")</td>
                        <td>@(item.UpdatedDate.HasValue ? item.UpdatedDate.Value.ToShortDateString() : "")</td>
                        <td>@item.isActive</td>

                        <td>
                            <div class="btn-group btn-group-sm">
                                @Html.ActionLink("Edit", "Edit", new { id = item.Id }, new { @class = "btn btn-outline-secondary" })
                                @Html.ActionLink("Details", "Details", new { id = item.Id }, new { @class = "btn btn-outline-info" })
                                @Html.ActionLink("Delete", "Delete", new { id = item.Id }, new { @class = "btn btn-outline-danger" })
                          
                                    <button class="btn btn-outline-primary sendEmailBtn"
                                            data-id="@item.Id"
                                            data-email="@item.Email"
                                            data-name="@item.Name">
                                        Send Email
                                    </button>
                                    <span class="email-status" id="status-@item.Id"></span>
                                
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
<!-- jQuery FIRST -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<!-- Then Bootstrap -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- Then DataTables (core + Bootstrap 5 styling) -->
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

<!-- If you're using Responsive mode -->
<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.5.0/js/responsive.bootstrap5.min.js"></script>

<script>
     $(document).on('click', '.sendEmailBtn', function () {
        var button = $(this);
        var companyId = button.data('id');
        var statusSpan = $('#status-' + companyId);

        // Optional UX changes
        button.prop('disabled', true).text('Sending...');
        statusSpan.html('<span class="spinner-border spinner-border-sm text-primary"></span>');

        $.ajax({
            url: '@Url.Action("SendEmail", "Company")',
            type: 'POST',
            data: { id: companyId },
            success: function (response) {
                if (response.success) {
                    statusSpan.html('<span class="text-success">Sent ✔</span>');
                } else {
                    statusSpan.html('<span class="text-danger">Failed ✖</span>');
                }
            },
            error: function () {
                statusSpan.html('<span class="text-danger">Error ✖</span>');
            },
            complete: function () {
                button.prop('disabled', false).text('Send Email');
            }
        });
    });

    $('#findMissingEmailsBtn').click(function () {
        $('#findMissingEmailsBtn').prop('disabled', true);
        $('#findText').text('Finding...')
        $('#findSpinner').removeClass('d-none');
        $('#findStatus').html('');

        $.ajax({
            url: '@Url.Action("findMissingEmails", "Company")',
            type: 'POST',
            success: function (response) {
                if (response.success) {
                    $('#findStatus').html('<span class="text-success">' + response.message + '</span>');
                } else {
                    $('#findStatus').html('<span class="text-danger">' + response.message + '</span>');
                }
            },
            error: function () {
                $('#findStatus').html('<span class="text-danger">Error occurred while searching for emails.</span>');
            },
            complete: function () {
                $('#findMissingEmailsBtn').prop('disabled', false);
                $('#findText').text('Find Missing Emails');
                $('#findSpinner').addClass('d-none');
            }
        });
    })

    $('#sendAllBtn').click(function () {
        // Disable the button
        $('#sendAllBtn').prop('disabled', true);
        $('#btnText').text('Sending...');
        $('#loadingSpinner').removeClass('d-none');

        $.ajax({
            url: '@Url.Action("sendToAll", "Company")',
            type: 'POST',
            success: function (response) {
                if (response.success) {
                    $('#sendStatus').html('<span class="text-success">' + response.message + '</span>');
                } else {
                    $('#sendStatus').html('<span class="text-danger">Failed to send emails.</span>');
                }
            },
            error: function () {
                $('#sendStatus').html('<span class="text-danger">Error occurred while sending emails.</span>');
            },
            complete: function () {
                // Re-enable the button
                $('#sendAllBtn').prop('disabled', false);
                $('#btnText').text('Send to All');
                $('#loadingSpinner').addClass('d-none');
            }
        });
    });



</script>