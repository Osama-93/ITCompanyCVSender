@model ITCompanyCVSender.Models.CompaniesEmailSentVM

@{
    ViewBag.Title = "Company Details";
    Layout = "~/Views/Shared/_Layout.cshtml"; // optional
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

<div class="container mt-5">
    <h2 class="mb-4">Company Details</h2>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">Company Info</div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Industry</dt>
                <dd class="col-sm-9">@Model.Industry</dd>

                <dt class="col-sm-3">Website</dt>
                <dd class="col-sm-9"><a href="@Model.Website" target="_blank">@Model.Website</a></dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.PhoneNumber</dd>

                <dt class="col-sm-3">LinkedIn</dt>
                <dd class="col-sm-9"><a href="@Model.LinkedInUrl" target="_blank">@Model.LinkedInUrl</a></dd>

                <dt class="col-sm-3">City</dt>
                <dd class="col-sm-9">@Model.City</dd>

                <dt class="col-sm-3">Contact Form</dt>
                <dd class="col-sm-9"><a href="@Model.ContactFormUrl" target="_blank">@Model.ContactFormUrl</a></dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Contact Name</dt>
                <dd class="col-sm-9">@Model.ContactName</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.PhoneNumber</dd>


                <dt class="col-sm-3">Notes</dt>
                <dd class="col-sm-9">@Model.Notes</dd>

                <dt class="col-sm-3">Date Added</dt>
                <dd class="col-sm-9">
                    @(Model.DateAdded.HasValue ? Model.DateAdded.Value.ToShortDateString() : "")
                </dd>
                <dt class="col-sm-3">Update</dt>
                <dd class="col-sm-9">
                    @(Model.DateAdded.HasValue ? Model.DateAdded.Value.ToShortDateString() : "")
                </dd>
            </dl>
        </div>
    </div>

    @if (Model.EmaisSentVM != null && Model.EmaisSentVM.Any())
    {
        <div class="card">
            <div class="card-header bg-success text-white">Emails Sent</div>
            <div class="card-body">
                <table class="table table-bordered table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Subject</th>
                            <th>Date Sent</th>
                            <th>Status</th>
                            <th>Response</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var email in Model.EmaisSentVM)
                        {
                            <tr>
                                <td>@email.Id</td>
                                <td>@email.Subject</td>
                                <td>@(email.DateSent.HasValue ? email.DateSent.Value.ToShortDateString() : "")</td>
                                <td>@email.Status</td>
                                <td>@email.Response</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <p class="text-muted">No emails sent yet.</p>
    }

    <div class="mt-4">
        @Html.ActionLink("Edit", "Edit", new { id = Model.Id }, new { @class = "btn btn-outline-secondary" }) |
        @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-outline-primary" })
    </div>
</div>
