@model ITCompanyCVSender.Models.CompanyVM

@{
    ViewBag.Title = "Edit Company";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <h2 class="mb-4">Edit Company Details</h2>

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.Id)

        <div class="row">
            <div class="col-md-8">
                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                @{
                    var fields = new[]
                    {
                        nameof(Model.Name), nameof(Model.Industry), nameof(Model.Website),
                        nameof(Model.Email), nameof(Model.PhoneNumber), nameof(Model.LinkedInUrl),
                        nameof(Model.City), nameof(Model.ContactFormUrl), nameof(Model.Status),
                        nameof(Model.ContactName),nameof(Model.AltEmail),
                        nameof(Model.AltNumber),nameof(Model.WhatsApp),
                        nameof(Model.Notes),nameof(Model.isActive)
                    };
                }

                @foreach (var field in fields)
                {
                    <div class="mb-3">
                        @Html.Label(field, htmlAttributes: new { @class = "form-label fw-bold" })

                        @if (field == nameof(Model.Notes))
                        {
                            @Html.TextArea(field, new { @class = "form-control", rows = 4 })
                        }
                        else
                        {
                            @Html.Editor(field, new { htmlAttributes = new { @class = "form-control" } })
                        }

                        @Html.ValidationMessage(field, "", new { @class = "text-danger" })
                    </div>
                }


                <div class="mb-4">
                    <input type="submit" value="Save Changes" class="btn btn-success" />
                    @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-secondary ms-2" })
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
