@model ITCompanyCVSender.Models.CompanyVM

@{
    ViewBag.Title = "Delete Company";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="card shadow-lg">
        <div class="card-body">
            <h2 class="text-danger mb-4">Are you sure you want to delete <span class="text-dark fw-bold">"@Model.Name"</span>?</h2>

            <dl class="row">
                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.Industry)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Industry)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.Website)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Website)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.Email)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Email)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.PhoneNumber)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.PhoneNumber)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.LinkedInUrl)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.LinkedInUrl)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.City)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.City)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.ContactFormUrl)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.ContactFormUrl)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.Status)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Status)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.Notes)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Notes)</dd>

                <dt class="col-sm-4 fw-bold">@Html.DisplayNameFor(model => model.DateAdded)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.DateAdded)</dd>
            </dl>

            @if (Model.EmaisSentVM != null && Model.EmaisSentVM.Any())
            {
                <div class="card mt-4 border-success">
                    <div class="card-header bg-success text-white fw-bold">Emails Sent</div>
                    <div class="card-body">
                        <table class="table table-striped table-bordered">
                            <thead class="table-success">
                                <tr>
                                    <th>#</th>
                                    <th>Subject</th>
                                    <th>Date Sent</th>
                                    <th>Status</th>
                                    <th>Response</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var email in Model.EmaisSentVM)
                                {
                                    <tr>
                                      
                                        <td>@email.Subject</td>
                                        <td>@(email.DateSent?.ToShortDateString())</td>
                                        <td>@email.Status</td>
                                        <td>@email.Response</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted mt-3">No emails sent yet.</p>
            }

            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                <div class="mt-4 d-flex">
                    <input type="submit" value="Delete" class="btn btn-danger me-3" />
                    @Html.ActionLink("Cancel", "Index", null, new { @class = "btn btn-outline-secondary" })
                </div>
            }
        </div>
    </div>
</div>
