@model ITCompanyCVSender.Models.CompanyVM

@{
    ViewBag.Title = "Create Company";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Container -->
<div class="container mt-5">
    <div class="card shadow-sm rounded-4 border-0">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h3 class="mb-0">Add New Company</h3>
        </div>
        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

            <div class="row g-3">
                <div class="col-md-6">
                    @Html.LabelFor(m => m.Name, new { @class = "form-label" })
                    @Html.EditorFor(m => m.Name, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.Industry, new { @class = "form-label" })
                    @Html.EditorFor(m => m.Industry, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.Industry, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.Website, new { @class = "form-label" })
                    @Html.EditorFor(m => m.Website, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.Website, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.Email, new { @class = "form-label" })
                    @Html.EditorFor(m => m.Email, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.PhoneNumber, new { @class = "form-label" })
                    @Html.EditorFor(m => m.PhoneNumber, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.LinkedInUrl, new { @class = "form-label" })
                    @Html.EditorFor(m => m.LinkedInUrl, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.LinkedInUrl, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.City, new { @class = "form-label" })
                    @Html.EditorFor(m => m.City, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.City, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.ContactFormUrl, new { @class = "form-label" })
                    @Html.EditorFor(m => m.ContactFormUrl, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.ContactFormUrl, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.Status, new { @class = "form-label" })
                    @Html.EditorFor(m => m.Status, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.Status, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.ContactName, new { @class = "form-label" })
                    @Html.EditorFor(m => m.ContactName, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.ContactName, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.AltEmail, new { @class = "form-label" })
                    @Html.EditorFor(m => m.AltEmail, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.AltEmail, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.AltNumber, new { @class = "form-label" })
                    @Html.EditorFor(m => m.AltNumber, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.AltNumber, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.WhatsApp, new { @class = "form-label" })
                    @Html.EditorFor(m => m.WhatsApp, new { htmlAttributes = new { @class = "form-control" } })
                    @Html.ValidationMessageFor(m => m.WhatsApp, "", new { @class = "text-danger" })
                </div>


                <div class="col-12">
                    @Html.LabelFor(m => m.Notes, new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.Notes, 4, 80, new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.Notes, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.isActive, new { @class = "form-label" })
                    @Html.EditorFor(m => m.isActive, new { htmlAttributes = new { @class = "" } })
                    @Html.ValidationMessageFor(m => m.isActive, "", new { @class = "text-danger" })
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(m => m.Country, new { @class = "form-label" })
                    @Html.EditorFor(m => m.Country, new { htmlAttributes = new { @class = "" } })
                    @Html.ValidationMessageFor(m => m.Country, "", new { @class = "text-danger" })
                </div>

                <div class="col-12 d-flex justify-content-end mt-4">
                    <input type="submit" value="Create" class="btn btn-success me-2" />
                    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-outline-secondary" })
                </div>
            </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
